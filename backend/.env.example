# Server
PORT=3000
NODE_ENV=development

# Firebase Admin SDK
# วิธีรับ: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# วาง JSON file ที่ได้ใน backend/firebase-service-account.json (อย่า commit ขึ้น git!)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# CORS
CORS_ORIGIN=http://localhost:8080,http://localhost:3000

# Logging
LOG_LEVEL=debug
